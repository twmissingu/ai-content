# ═══════════════════════════════════════════════════════════════════════
# 稿定 — AI Content Production System Docker 配置模板
# 复制本文件为 .env 并填入你的配置：
#   cp .env.docker.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────────
# 必填。LLM API 地址，兼容 OpenAI 格式。
LLM_BASE_URL="https://api.xiaomimimo.com/v1"

# 必填。LLM API Key
XIAOMI_API_KEY="your-api-key-here"

# 模型名称（可选，默认 mimo-v2.5）
LLM_MODEL="mimo-v2.5"

# ── Feishu Notification ─────────────────────────────────────────────
# 飞书 Webhook URL（可选，用于接收系统告警通知）
FEISHU_WEBHOOK_URL=""

# ── Budget ───────────────────────────────────────────────────────────
# 月度预算上限（美元，可选，默认 15）
MONTHLY_BUDGET_USD=15

# ── Application ─────────────────────────────────────────────────────
# 应用端口（可选，默认 8710）
APP_PORT=8710
