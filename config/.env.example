# ═══════════════════════════════════════════════════════════════════════
# 稿定 — AI Content Production System 配置模板
# 复制本文件为 .env （已在 .gitignore 中）并填入你的配置：
#   cp config/.env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────────────────────────
# 必填。LLM API Key，用于 Scout/Writer/Feedback 等 Agent 调用大模型。
# 支持小米 MiMo / 兼容 OpenAI 格式的任意 API。
XIAOMI_API_KEY=""

# LLM API 基础地址（可选，默认小米 MiMo）
LLM_BASE_URL="https://api.xiaomimimo.com/v1"

# 模型名称（可选，默认 mimo-v2.5）
LLM_MODEL="mimo-v2.5"

# 最大输出 Token（可选，默认 131072）
# LLM_MAX_TOKENS=131072

# ── Schedules ────────────────────────────────────────────────────────
# 每日选题时间（可选，默认 09:00 / 14:00）
# MORNING_SCOUT="09:00"
# EVENING_SCOUT="14:00"

# ── Writer Defaults ──────────────────────────────────────────────────
# 写作领域（可选，默认 "科技/AI"）
# DOMAIN="科技/AI"
# 文章语调（可选，默认 "口语化"）
# TONE="口语化"
# 立场（可选，默认 "强烈观点"）
# STANCE="强烈观点"
# 目标字数（可选，默认 2500）
# LENGTH=2500

# ── Budget ───────────────────────────────────────────────────────────
# 月度预算上限（美元，可选，默认 15）
# MONTHLY_BUDGET_USD=15
# 预算告警阈值比例（可选，默认 0.8）
# COST_WARN_PCT=0.8
